// ULTRA-SIMPLE CANDY TEST
window(400, 400, "Candy Test")
fps(60)

x = 100
y = 100

repeat 5 {
  print("Repeating...")
}

loop {
  clear(BLUE)
  
  circle(x, y, 20, RED)
  box(200, 200, 50, 50, GOLD)
  text("Hello Candy!", 10, 10, 20, WHITE)
  
  if key("RIGHT") { x = x + 2 }
  if key("LEFT")  { x = x - 2 }
  if key("UP")    { y = y - 2 }
  if key("DOWN")  { y = y + 2 }
  
  if clicked() {
    print("Clicked at: " + mouseX() + ", " + mouseY())
  }
  
  show()
  
  if key("ESCAPE") { exit() }
}
