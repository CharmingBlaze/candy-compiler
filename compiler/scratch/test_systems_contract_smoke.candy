import candy.2d
import candy.3d
import candy.physics2d
import candy.physics3d
import candy.ui
import candy.scene
import candy.audio
import candy.input
import candy.resources
import candy.save
import candy.debug
import candy.state
import candy.camera
import candy.ai
import candy.game3d
import candy.proc
import candy.vfx
import candy.editor
import candy.network

fun noop(dt) {}

fun main() {
    // 2D / 3D surface constructors
    var e2 = Entity2D()
    var s2 = Sprite()
    var a2 = AnimatedSprite()
    e2.addChild(s2)
    e2.addChild(a2)

    var e3 = Entity3D()
    var m3 = Model()
    var c3 = Camera3D()
    e3.addChild(m3)
    c3.lookAt(vec3(0, 0, 0))

    // Physics
    var p2 = Physics2D()
    var rb2 = RigidBody2D()
    rb2.applyForce(vec2(1, 2))
    p2.add(rb2)
    p2.update(0.016)

    var p3 = Physics3D()
    var rb3 = RigidBody3D()
    rb3.applyForce(vec3(1, 2, 3))
    p3.add(rb3)
    p3.update(0.016)

    // Universal systems
    var canvas = Canvas()
    canvas.add(Label({"text": "ok"}))

    var scene = Scene()
    scene.add(e2)
    SceneManager.change(scene)
    SceneManager.update(0.016)

    var sm = StateMachine()
    sm.addState("idle", {"update": noop})
    sm.change("idle")
    sm.update(0.016)

    var cam2 = Camera2D()
    cam2.follow(vec2(10, 10), 0.2)

    var agent = SteeringAgent()
    agent.init({})
    agent.applyForce(agent.wander())
    agent.update(0.016)

    var rig = ThirdPersonRig(null)
    rig.update(0.016)

    var gen = DungeonGenerator(12, 12)
    gen.generate()
    var t = gen.getTile(0, 0)

    var fx = PostProcess()
    fx.enable(Effects.Bloom)
    fx.disable(Effects.Bloom)

    Input.map("jump", [KEY_SPACE])
    Resources.preload([])
    Save.set("k", 1)
    var got = Save.get("k", 0)

    // Avoid draw/audio calls requiring active window/audio devices in smoke.
    Console.log("systems-contract-smoke")

    // Network constructors only in this smoke (transport is covered in evaluator tests).
    var server = NetworkServer(19421, 4, 2)
    server.stop()
    var client = NetworkClient(2)
    client.stop()

    print("systems contract smoke ok {t} {got}")
}

main()
