{
  "scopeName": "source.candy",
  "name": "Candy",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#constants"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.candy",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.candy",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.candy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.candy",
              "match": "\\\\."
            },
            {
              "name": "variable.interpolation.candy",
              "match": "\\{[A-Za-z_][A-Za-z0-9_]*\\}"
            }
          ]
        },
        {
          "name": "string.quoted.single.candy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.candy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.candy",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.candy",
          "match": "\\b(if|else|while|for|foreach|repeat|loop|switch|case|default|break|continue|return|try|catch|finally|with|delete|defer|when|match)\\b"
        },
        {
          "name": "keyword.declaration.candy",
          "match": "\\b(fun|function|extern|import|module|library|type|struct|class|object|enum|interface|trait|package|var|val|const)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.candy",
          "match": "\\b(int|float|string|bool|void|any|null|bytes|array|map)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.candy",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.candy",
          "match": "\\+\\+|--|\\+=|-=|\\*=|/=|==|!=|<=|>=|&&|\\|\\||\\?\\.|\\?\\?|\\.\\.<|\\.\\.|<<|>>|[+\\-*/%<>=!&|^~]"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.candy",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    }
  }
}
